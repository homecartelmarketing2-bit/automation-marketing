# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Kie.ai ──
KIE_API_KEY=your_kie_api_key_here

# ── Airtable ──
AIRTABLE_TOKEN=your_airtable_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here

# ── Zoho WorkDrive ──
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here

# ── Zoho Folder IDs ──
ZOHO_FOLDER_STYLED_PHOTO=your_folder_id
ZOHO_FOLDER_BLENDED_IMAGE=your_folder_id
ZOHO_FOLDER_MOODBOARD=your_folder_id
ZOHO_FOLDER_STYLED_REELS=your_folder_id
ZOHO_FOLDER_BEFORE_AND_AFTER_REELS=your_folder_id
ZOHO_FOLDER_BEFORE_AND_AFTER_FEEDS=your_folder_id
ZOHO_FOLDER_BEFORE_REELS=your_folder_id
ZOHO_FOLDER_AFTER_REELS=your_folder_id

# ── Vision LLM ──
VISION_LLM_MODEL=zai-org/glm-4.6v-flash
VISION_LLM_ENDPOINTS=http://192.168.2.166:1234/v1/chat/completions
VISION_LLM_TIMEOUT=120

# ── Local Photo Directory ──
LOCAL_PHOTO_DIR=C:\Users\User\Downloads\photos
